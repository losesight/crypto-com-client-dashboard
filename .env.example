# Panel host — admin dashboard is only served on this hostname.
# All other hostnames registered in custom_domains serve visitor templates only.
PANEL_HOST=345235fgdfgdgdgdgd.shop

# Do NOT set ORIGIN to http://127.0.0.1 — it breaks panel routing. Omit ORIGIN or use your panel URL:
# ORIGIN=https://345235fgdfgdgdgdgd.shop

# Behind Cloudflare / reverse proxy — use the header that carries the real client IP.
# Without this, sessions show 127.0.0.1 and IP-based actions miss the right visitor.
# ADDRESS_HEADER=CF-Connecting-IP

# Optional admin credentials (defaults: apollo / apollo123)
# ADMIN_USERNAME=apollo
# ADMIN_PASSWORD=your-secure-password

# Optional API / integration keys
# API_KEY=
# CLOUDFLARE_API_TOKEN=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
